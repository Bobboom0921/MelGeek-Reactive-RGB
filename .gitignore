# Build artifacts
build/
dist/

# Runtime outputs (logs, configs, binaries)
outputs/

# Runtime caches
__pycache__/
*.py[cod]
*.log
*.jsonl
*.tmp
*.bak

# Local experimental / debug scripts (kept in archive/ locally, not uploaded)
archive/

# BlackScreenESC (local tool, not part of public release)
tools/BlackScreenESC/

# Packaged binaries and PyInstaller payloads
*.exe
*.pkg

# Crash dumps and local stores
*.dmp
*.pma
*.sqlite-shm
*.sqlite-wal

# Legacy work/ directory (Edge profile caches, etc.)
work/

# Local editor/system files
.DS_Store
Thumbs.db
.vscode/
.idea/
